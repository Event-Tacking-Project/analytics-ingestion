# =========================
# SERVER CONFIG
# =========================

PORT=3000
ENV=development

# =========================
# REDIS (event queue + cache)
# =========================

REDIS_URL=redis://localhost:6379

# Optional tuning later
REDIS_QUEUE_NAME=events_queue

# =========================
# POSTGRES (optional in Crystal phase 1,
# only used if you later add validation or key lookup here)
# =========================

DATABASE_URL=postgres://user:password@localhost:5432/analytics

# =========================
# AUTH / API KEYS
# =========================

# In Phase 1 this may be hardcoded or Redis-backed
API_KEY_SALT=dev_salt_change_me

# =========================
# INGESTION SETTINGS
# =========================

MAX_PAYLOAD_SIZE=1048576
RATE_LIMIT_PER_MINUTE=1000

# =========================
# LOGGING
# =========================

LOG_LEVEL=debug

# =========================
# FUTURE (ignore for now, but reserved)
# =========================

# ENABLE_REDIS_STREAMS=false
# ENABLE_EVENT_BATCHING=false